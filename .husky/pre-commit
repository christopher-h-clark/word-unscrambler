#!/bin/sh
set -e

echo "Running pre-commit checks..."

echo "1/2: Linting and formatting staged files..."
npx lint-staged || { echo "❌ Lint-staged failed. Fix issues and retry."; exit 1; }

echo "2/2: Running tests (this may take a minute)..."
npm run test:run || { echo "❌ Tests failed. Fix failing tests and retry."; exit 1; }

echo "✅ All pre-commit checks passed!"
echo "Note: Type checking will be validated in CI pipeline."
